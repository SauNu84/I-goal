# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/i_goal?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# AI Provider: "openai" (default), "anthropic", or "lmstudio"
AI_PROVIDER=openai

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic (required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
